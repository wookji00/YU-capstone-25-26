<mujoco model="rrr_robot">

    <compiler angle="radian"/>

    <option gravity="0 0 -9.81"/>

    <worldbody>

        <!-- 바닥 -->
        <geom type="plane"
              size="2 2 0.1"
              rgba="0.9 0.9 0.9 1"/>

        <!-- 조명 -->
        <light pos="0 0 3"/>

        <!-- Base -->
        <body name="base" pos="0 0 0">

            <!-- base 시각화 -->
            <joint name="joint1"
                   type="hinge"
                   axis="0 0 1"
                   damping="2"/>

            <geom type="cylinder"
                  size="0.08 0.1"
                  rgba="0.3 0.3 0.3 1"/>

            <!-- ========================= -->
            <!-- Joint 1 : Base Yaw 실제로 우리는 base와 link1간 각도 고정함-->
            <!-- ========================= -->

            <body name="link1" pos="0 0 0.1" euler="0 75 0">

                <!-- 링크1 -->
                <geom type="capsule"
                      fromto="0 0 0 0 0 0.35"
                      size="0.03"
                      rgba="1 0 0 1"/>

                <!-- ========================= -->
                <!-- Joint 2 : Shoulder Pitch -->
                <!-- ========================= -->

                <body name="link2" pos="0 0 0.35">

                    <joint name="joint2"
                           type="hinge"
                           axis="0 1 0"
                           damping="2"/>

                    <!-- 링크2 -->
                    <geom type="capsule"
                          fromto="0 0 0 0 0 0.30"
                          size="0.025"
                          rgba="0 1 0 1"/>

                    <!-- ========================= -->
                    <!-- Joint 3 : Elbow Pitch -->
                    <!-- ========================= -->

                    <body name="link3" pos="0 0 0.30">

                        <joint name="joint3"
                              type="hinge"
                              axis="0 1 0"
                              damping="2"/>

                        <!-- 링크3 -->
                        <geom type="capsule"
                              fromto="0 0 0 0 0 0.30"
                              size="0.02"
                              rgba="0 0 1 1"/>

                        <body name="link4" pos="0 0 0.30">
      
                            <joint name="joint4"
                                  type="hinge"
                                  axis="0 1 0"
                                  damping="2"/>

                            <!-- 링크3 -->
                            <geom type="capsule"
                                  fromto="0 0 0 0 0 0.075"
                                  size="0.02"
                                  rgba="0 0 1 1"/>

                            <!-- End Effector -->
                            <site name="ee"
                                  pos="0 0 0.075"
                                  size="0.02"
                                  rgba="1 1 0 1"/>
                          <!-- ========================= -->
                          <!-- SIMPLE GRIPPER -->
                          <!-- ========================= -->

                          <!--FINGER rotate-->
                            <body name="finger_base" pos="0 0 0.075">

                                <joint name="joint5"
                                      type="hinge"
                                      axis="0 0 -1"
                                      />

                                <!-- finger base -->
                                <geom type="box"
                                      size="0.03 0.05 0.02"
                                      rgba="0.2 0.2 0.2 1"/>
                                <body name="left" pos="0 0.04 0.02">

                                    <joint name="lefty"
                                          type="hinge"
                                          axis="1 0 0"
                                          range="0 0.8"/>

                                    <!-- 손가락 -->
                                    <geom type="box"
                                          pos="0 0 0.04"
                                          size="0.005 0.005 0.04"
                                          rgba="0.2 0.2 0.2 1"/>

                                </body>

                                <body name="right" pos="0 -0.04 0.02">

                                    <joint name="righty"
                                          type="hinge"
                                          axis="-1 0 0"
                                          range="0 0.8"/>

                                    <!-- 손가락 -->
                                    <geom type="box"
                                          pos="0 0 0.04"
                                          size="0.005 0.005 0.04"
                                          rgba="0.2 0.2 0.2 1"/>

                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <!-- ========================= -->
    <!-- Actuators -->
    <!-- ========================= -->

    <actuator>

        <position joint="joint1"
                  kp="30"/>

        <position joint="joint2"
                  kp="30"/>

        <position joint="joint3"
                  kp="30"/>
        <position joint="joint4" kp="10"/>
        <position joint="joint5" kp="10"/>
        <position joint="lefty" kp ="10"/>
        <position joint="righty" kp ="10"/>
    </actuator>
    <equality>
        <joint joint1="lefty" joint2="righty" polycoef="0 -1 0 0 0"/>
    </equality>
</mujoco>
